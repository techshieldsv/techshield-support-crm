rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /companies/{companyId}/{allPaths=**} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if signedIn();
    }
  }
}
